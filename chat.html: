<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KAIFMANIA</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        body { background: #000; color: white; font-family: sans-serif; margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

        /* ზედა ზოლი - ღაჟღაჟა წითელი ხაზით */
        .header { background: #000; border-bottom: 2px solid #ff0000; padding: 10px; display: flex; align-items: center; box-shadow: 0 2px 15px rgba(255, 0, 0, 0.5); z-index: 100; }
        .logo { color: #ff0000; font-weight: bold; font-size: 18px; letter-spacing: 2px; flex: 1; text-align: center; }
        
        /* ჰამბურგერი - მარტო ხაზები */
        .menu-btn { background: none; border: 1px solid #ff0000; color: #ff0000; padding: 5px 12px; border-radius: 5px; font-size: 24px; cursor: pointer; }

        /* ჩამოსაშლელი მენიუ - ერთ სვეტად */
        .dropdown-menu { 
            position: absolute; top: 55px; left: -100%; width: 260px; height: calc(100vh - 55px);
            background: rgba(5, 0, 0, 0.98); border-right: 2px solid #ff0000; transition: 0.4s; 
            z-index: 99; padding: 15px; box-sizing: border-box; display: flex; flex-direction: column;
        }
        .dropdown-menu.open { left: 0; }

        /* პროფილი: ავატარი ნიკის გვერდით */
        .profile-box { display: flex; align-items: center; gap: 12px; background: #000; padding: 10px; border-radius: 10px; border: 1px solid #ff0000; margin-bottom: 15px; }
        .profile-box img { width: 55px; height: 55px; border-radius: 50%; border: 2px solid #ff0000; object-fit: cover; }
        .profile-box div { display: flex; flex-direction: column; }
        .profile-box b { color: #ff0000; font-size: 16px; }
        .profile-box span { color: gold; font-size: 12px; font-weight: bold; }

        /* ოთახების სია */
        .room-list { flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 5px; }
        .room { background: #0a0a0a; border: 1px solid #222; color: white; padding: 12px; border-radius: 8px; cursor: pointer; text-align: left; font-size: 14px; }
        .room:hover { border-color: #ff0000; background: #150000; }

        /* ჩატის ზონა */
        #chatBox { flex: 1; overflow-y: auto; padding: 15px; display: flex; flex-direction: column; gap: 10px; background: #000; }
        .msg { background: #080808; border-left: 4px solid #ff0000; padding: 10px; border-radius: 10px; max-width: 85%; box-shadow: 2px 2px 10px #000; }
        .msg b { color: #ff0000; font-size: 13px; display: block; margin-bottom: 2px; }

        /* ქვედა ზოლი - დიდი გრაფა */
        .footer { padding: 15px; background: #000; border-top: 1px solid #222; display: flex; gap: 10px; align-items: center; }
        input { flex: 1; padding: 14px; border-radius: 10px; border: 1px solid #444; background: #0a0a0a; color: white; outline: none; font-size: 15px; }
        .send-btn { background: #ff0000; color: #000; border: none; width: 55px; height: 55px; border-radius: 15px; font-size: 28px; cursor: pointer; box-shadow: 0 0 15px #ff0000; }

        .exit-link { color: #ff0000; text-decoration: none; font-size: 13px; text-align: center; margin-top: 15px; display: block; border: 1px solid #400; padding: 8px; border-radius: 5px; }
    </style>
</head>
<body>

<div class="header">
    <button class="menu-btn" onclick="toggleMenu()">☰</button>
    <div class="logo">KAIFMANIA</div>
</div>

<div id="dropMenu" class="dropdown-menu">
    <div class="profile-box">
        <img id="my-ava" src="https://i.ibb.co/v3m6y6R/avatar.png">
        <div>
            <b id="my-nick">...</b>
            <span id="my-role">დამფუძნებელი 👑</span>
        </div>
    </div>
    
    <div class="room-list">
        <div class="room">☕ კაფე-ბარი</div>
        <div class="room">💎 ვიპ საუბრები</div>
        <div class="room">🧛 მაფიის ღამე</div>
        <div class="room">🕵️ გამოძიება</div>
        <div class="room">🔐 შიფროგრამა</div>
        <div class="room">❓ ვიქტორინა</div>
        <div class="room">😵 ჩამოხრჩობანა</div>
        <div class="room">🃏 კარტი</div>
        <div class="room">🎰 კაზინო</div>
        <div class="room">⚔️ დუელი</div>
        <div class="room">🏰 ციხესიმაგრე</div>
        <div class="room">🎤 კარაოკე</div>
    </div>
    
    <a href="index.html" class="exit-link" onclick="localStorage.clear()">გასვლა 🚪</a>
</div>

<div id="chatBox"></div>

<div class="footer">
    <input type="text" id="msgInp" placeholder="დაწერე რამე...">
    <button class="send-btn" onclick="sendMsg()">✈️</button>
</div>

<script>
    const _s = supabase.createClient("https://ftfciebnywbondaiarnc.supabase.co", "sb_publishable_eQZDSu_Jy1gWmXJFF800Pw_TP2kBRLI");
    const myNick = localStorage.getItem('nickname');

    function toggleMenu() {
        document.getElementById('dropMenu').classList.toggle('open');
    }

    async function loadData() {
        if (!myNick) return;
        const { data: p } = await _s.from('profiles').select('*').eq('username', myNick).maybeSingle();
        if (p) {
            document.getElementById('my-nick').innerText = p.username;
            if (p.avatar_url) document.getElementById('my-ava').src = p.avatar_url;
        }

        const { data: msgs } = await _s.from('messages').select('*').order('created_at', { ascending: true }).limit(50);
        const box = document.getElementById('chatBox');
        box.innerHTML = '';
        msgs?.forEach(m => {
            box.innerHTML += `<div class="msg"><b>${m.username || 'უცნობი'}</b><span>${m.text}</span></div>`;
        });
        box.scrollTop = box.scrollHeight;
    }

    async function sendMsg() {
        const inp = document.getElementById('msgInp');
        if (!inp.value.trim()) return;
        await _s.from('messages').insert([{ username: myNick, text: inp.value }]);
        inp.value = '';
        loadData();
    }

    _s.channel('chat').on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages' }, loadData).subscribe();
    window.onload = loadData;
    document.getElementById('msgInp').onkeypress = (e) => { if(e.key === "Enter") sendMsg(); };
</script>

</body>
</html>
